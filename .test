module.exports = {
    async execute(sock, msg, from, args) {
        const questions = [
            "لو خيروك: تعيش في غابة لوحدك 🌲 أو تعيش في مدينة كلها مجرمين 🏙️؟",
            "لو خيروك: تمتلك القدرة على الطيران 🦅 أو القدرة على الاختفاء 👻؟",
            "لو خيروك: تأكل وجبتك المفضلة طوال العمر 🍔 أو تسافر لأي دولة مجاناً ✈️؟"
        ];
        const randomQuestion = questions[Math.floor(Math.random() * questions.length)];
        await sock.sendMessage(from, { text: `🎮 *لعبة لو خيروك* 🎮\n\n${randomQuestion}` });
    }
};
